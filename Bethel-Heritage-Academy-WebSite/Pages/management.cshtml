@page
@model Bethel_Heritage_Academy_WebSite.Pages.managementModel
@{
    ViewData["Title"] = "Management";
}
<section class="relative pt-40 pb-20 bg-brand-blue overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h1 class="font-serif text-5xl font-bold text-white mb-4">School Leadership</h1>
        <p class="text-blue-200 text-lg max-w-2xl mx-auto">Meet the dedicated team driving our vision of excellence.</p>
    </div>
    <!-- Bottom Wave -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none"><svg class="relative block w-[calc(100%+1.3px)] h-[50px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none"><path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="fill-slate-50"></path></svg></div>
</section>

<!-- Main Content -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">

    <!-- Proprietress Feature -->
    <div class="bg-white rounded-3xl shadow-xl overflow-hidden mb-16 border border-slate-100">
        <div class="flex flex-col md:flex-row">
            <div class="md:w-1/3 relative h-96 md:h-auto">
                <img src="~/images/proprietress1.png" alt="Mrs. Juliet Iorsue" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/80 to-transparent md:bg-gradient-to-r flex items-end md:hidden p-6">
                    <div class="text-white">
                        <h2 class="font-serif text-3xl font-bold">Mrs. Juliet Iorsue</h2>
                        <p class="text-brand-red font-bold">Founder & Proprietress</p>
                    </div>
                </div>
            </div>
            <div class="md:w-2/3 p-10 md:p-14 flex flex-col justify-center">
                <div class="hidden md:block mb-6">
                    <span class="text-brand-red font-bold uppercase tracking-widest text-xs">The Visionary</span>
                    <h2 class="font-serif text-4xl font-bold text-brand-blue mt-2">Mrs. Juliet Iorsue</h2>
                    <p class="text-xl text-slate-500 font-medium mt-1">Founder & Proprietress</p>
                </div>

                <div class="space-y-6 text-slate-600 leading-relaxed">
                    <p>Mrs. Juliet Iorsue is the visionary leader behind Bethel Heritage Academy. A graduate of Benue State University (now Rev. Father Moses Adasu University), she studied Theatre Arts and has received additional professional training in Children’s Programs through VOS (UK) and Accelerated Christian Education (ACE), Jos, Plateau State.</p>
                    <p>Driven by faith and a passion for child development, she founded Bethel Heritage Academy to provide structured, Christ-centered education that empowers children for lifelong success.</p>
                </div>

                <div class="mt-8 flex flex-wrap gap-4">
                    <div class="flex items-center gap-2 bg-blue-50 px-4 py-2 rounded-lg">
                        <i class="fas fa-graduation-cap text-brand-blue"></i>
                        <span class="text-sm font-semibold text-slate-700">Theatre Arts</span>
                    </div>
                    <div class="flex items-center gap-2 bg-blue-50 px-4 py-2 rounded-lg">
                        <i class="fas fa-certificate text-brand-blue"></i>
                        <span class="text-sm font-semibold text-slate-700">VOS (UK) Certified</span>
                    </div>
                    <div class="flex items-center gap-2 bg-blue-50 px-4 py-2 rounded-lg">
                        <i class="fas fa-child text-brand-blue"></i>
                        <span class="text-sm font-semibold text-slate-700">Child Development Expert</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Team Grid -->
    <h3 class="font-serif text-3xl font-bold text-brand-blue mb-8 text-center">Our Administration</h3>
    <div class="grid md:grid-cols-3 gap-8">
        <!-- Admin 1 -->
        @foreach (var item in Model.team)
        {
            <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center">
                <img src="@(item.ImagePath)" class="w-32 h-32 rounded-full mx-auto mb-4 object-cover border-4 border-brand-lightBlue">
                <h4 class="font-bold text-lg text-slate-800">@(item.Fullname)</h4>
                <p class="text-brand-red font-medium text-sm mb-3">@(item.Position)</p>
                <p class="text-slate-500 text-sm">@(item.Note)</p>
            </div>
        }
    </div>
</main>