@page
@model Bethel_Heritage_Academy_WebSite.Pages.blogModel
@{
    ViewData["Title"] = "School News & Blog";
}
<section class="relative pt-40 pb-20 bg-brand-blue overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h1 class="font-serif text-5xl font-bold text-white mb-4">School News & Blog</h1>
        <p class="text-blue-200 text-lg">Latest updates, achievements, and educational tips.</p>
    </div>
</section>

<!-- News Grid -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <!-- Articles -->
        @foreach(var item in Model.List.Data)
        {
            <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all group border border-slate-100">
                <div class="h-56 overflow-hidden relative">
                    <span class="absolute top-4 left-4 bg-brand-red text-white text-xs font-bold px-3 py-1 rounded-full z-10">@(item.Category)</span>
                    <img src="@(item.ImagePath)" alt="Admissions" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-2 text-slate-400 text-xs mb-3">
                        <i class="far fa-calendar"></i> @(item.CreatedDate.ToLongDateString())
                    </div>
                    <h2 class="font-serif text-xl font-bold text-brand-blue mb-3 group-hover:text-brand-red transition-colors">@(item.Headline)</h2>
                    <p class="text-slate-600 text-sm mb-4 line-clamp-3">
                        @ST.TruncateHtml(item.NewBody, 150)
                    </p>
                    <a asp-page="/news-detail" asp-route-id="@(item.Id)" class="inline-flex items-center text-brand-red font-bold text-sm hover:underline">
                        Read Full Story <i class="fas fa-arrow-right ml-2 text-xs"></i>
                    </a>
                </div>
            </article>
        }
    </div>

    <!-- Pagination -->
    <div class="flex justify-center mt-8">
        <nav aria-label="Pagination" class="isolate inline-flex rounded-lg shadow-sm">
            <cs-pager cs-paging-pagenumber="@Model.List.PageNumber"
                      cs-paging-totalitems="@Model.List.TotalItems"
                      cs-paging-pagesize="@Model.List.PageSize"
                      cs-pagenumber-param="p"
                      cs-pager-li-current-class="relative z-10 inline-flex items-center bg-brand-blue px-4 py-2 text-sm font-semibold text-white focus:z-20"
                      cs-pager-li-non-active-class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 focus:z-20"
                      cs-pager-li-first-class="relative inline-flex items-center rounded-l-lg px-3 py-2 text-sm font-semibold text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 focus:z-20"
                      cs-pager-li-last-class="relative inline-flex items-center rounded-r-lg px-3 py-2 text-sm font-semibold text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 focus:z-20"
                      cs-pager-link-current-class="relative z-10 inline-flex items-center bg-brand-blue px-4 py-2 text-sm font-semibold text-white focus:z-20"
                      cs-pager-link-other-class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus:z-20"></cs-pager>
        </nav>
    </div>
</main>