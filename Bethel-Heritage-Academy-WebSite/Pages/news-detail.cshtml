@page
@using Bethel_Heritage_Academy_WebSite.Services
@using TheAgooProjectDataAccess
@model Bethel_Heritage_Academy_WebSite.Pages.news_detailModel
@{
    ViewData["Title"] = "News Detail";
}
<main class="pt-28 pb-20 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Breadcrumbs -->
    <div class="text-sm text-slate-500 mb-6">
        <a asp-page="blog" class="hover:text-brand-blue">News</a> <span class="mx-2">/</span> <span class="text-slate-800">@(Model.newsTable.Headline)</span>
    </div>

    <!-- Header -->
    <span class="inline-block py-1 px-3 border border-brand-red text-brand-red rounded-full text-xs font-bold mb-4 uppercase tracking-wider">@(Model.newsTable.Category)</span>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-brand-blue mb-6">
        @(Model.newsTable.Headline)
    </h1>

    <div class="flex items-center gap-4 mb-8 border-b border-slate-200 pb-8">
        <div class="flex items-center gap-2">
            <img src="https://picsum.photos/seed/avatar/100/100" class="w-10 h-10 rounded-full object-cover">
            <span class="text-sm font-medium text-slate-700">@(Model.newsTable.Reporter)</span>
        </div>
        <div class="text-slate-400">|</div>
        <div class="text-slate-500 text-sm">@(Model.newsTable.CreatedDate.ToLongDateString())</div>
        <div class="text-slate-400">|</div>
        <div class="text-slate-500 text-sm"><i class="far fa-clock"></i> 
            @(ST.GetRelativeTime(Model.newsTable.CreatedDate)) read
            
        </div>
    </div>

    <!-- Featured Image -->
    <img src="@(Model.newsTable.ImagePath)" alt="Students" class="w-full h-auto rounded-2xl shadow-lg mb-10">

    <!-- Article Body -->
    <div class="prose prose-lg prose-headings:font-serif prose-a:text-brand-red max-w-none text-slate-600 leading-relaxed">
        <p class="">
            @(Html.Raw(Model.newsTable.NewBody))
        </p>

        <div class="bg-brand-lightBlue p-6 rounded-xl mt-8 flex items-center justify-between">
            <div>
                <h4 class="font-bold text-brand-blue text-lg">Ready to Enroll?</h4>
                <p class="text-sm text-slate-600">Contact us today to schedule a tour.</p>
            </div>
            <a asp-page="contact-us" class="bg-brand-red text-white px-6 py-3 rounded-lg font-bold hover:bg-red-700 transition-colors">Contact Us</a>
        </div>
    </div>
</main>