@page
@inject IConfiguration _configuration
@model Bethel_Heritage_Academy_WebSite.Pages.contact_usModel
@{
    ViewData["Title"] = "Contact Us";
}
<section class="relative pt-40 pb-20 bg-brand-blue overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h1 class="font-serif text-5xl font-bold text-white mb-4">Contact Us</h1>
        <p class="text-blue-200 text-lg">We are here to answer your questions.</p>
    </div>
    <!-- Bottom Wave -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none"><svg class="relative block w-[calc(100%+1.3px)] h-[50px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none"><path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="fill-slate-50"></path></svg></div>
</section>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-20 pb-20">
    <div class="grid lg:grid-cols-2 gap-8">

        <!-- Contact Form Card -->
        <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 order-2 lg:order-1">
            <h2 class="font-serif text-3xl font-bold text-brand-blue mb-6">Send us a Message</h2>
            
            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                var isSuccess = Model.StatusMessage.StartsWith("Success");
                <div class="mb-4 p-4 rounded-lg @(isSuccess ? "bg-green-100 text-green-700 border border-green-300" : "bg-red-100 text-red-700 border border-red-300")">
                    @Model.StatusMessage.Replace("Success: ", "").Replace("Error: ", "")
                </div>
            }

            <form id="contactForm" asp-page-handler="Post" method="post" class="space-y-6">
                <div>
                    <label asp-for="FeedBack.Name" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="FeedBack.Name" type="text" class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 outline-none transition-all" placeholder="John Doe">
                    <span asp-validation-for="FeedBack.Name" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="FeedBack.Email" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="FeedBack.Email" type="email" class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 outline-none transition-all" placeholder="email@example.com">
                    <span asp-validation-for="FeedBack.Email" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="FeedBack.Subject" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="FeedBack.Subject" type="text" class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 outline-none transition-all" placeholder="General Inquiry">
                    <span asp-validation-for="FeedBack.Subject" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="FeedBack.Message" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <textarea asp-for="FeedBack.Message" rows="4" class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/20 outline-none transition-all" placeholder="How can we help you?"></textarea>
                    <span asp-validation-for="FeedBack.Message" class="text-red-500 text-sm"></span>
                </div>

                <!-- Google reCAPTCHA -->
                <div>
                    <div id="recaptchaContainer" class="flex justify-center md:justify-start">
                        <div class="g-recaptcha" data-sitekey="@(_configuration["ReCaptcha:SiteKey"])"></div>
                    </div>
                    <span class="text-red-500 text-sm hidden" id="recaptchaError">Please complete the reCAPTCHA verification</span>
                </div>

                <button type="submit" id="submitBtn" class="w-full bg-brand-red hover:bg-red-700 text-white font-bold py-4 rounded-lg transition-colors shadow-lg shadow-red-500/30 flex items-center justify-center gap-2">
                    Send Message <i class="fas fa-paper-plane"></i>
                </button>
            </form>
        </div>

        <!-- Info & Map Card -->
        <div class="space-y-8 order-1 lg:order-2">
            <!-- Info -->
            <div class="bg-brand-blue text-white rounded-2xl shadow-xl p-8 md:p-10">
                <h2 class="font-serif text-3xl font-bold mb-8">Get in Touch</h2>
                <div class="space-y-8">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-map-marker-alt text-brand-red text-lg"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg mb-1">Address</h4>
                            <p class="text-blue-100 text-sm leading-relaxed">No. 18, Off Iorhum Road, Behind Ultra Modern International Market, Pevigo Close, Makurdi.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-phone-alt text-brand-red text-lg"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg mb-1">Phone</h4>
                            <p class="text-blue-100 text-sm">0811 715 7565</p>
                            <p class="text-blue-100 text-sm">0803 528 4668</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-envelope text-brand-red text-lg"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg mb-1">Email</h4>
                            <p class="text-blue-100 text-sm">info@bethelheritageacademy.com.ng</p>
                        </div>
                    </div>
                </div>

                <div class="mt-10 pt-8 border-t border-white/20">
                    <h4 class="font-bold text-lg mb-2">Office Hours</h4>
                    <p class="text-blue-100 text-sm">Monday – Friday</p>
                    <p class="text-2xl font-serif font-bold text-white">8:00 AM – 4:00 PM</p>
                </div>
            </div>

            <!-- Google Map -->
            <div class="h-80 w-full rounded-2xl shadow-xl overflow-hidden map-container relative">
                <!-- Using a generic Makurdi coordinate centered on the Wurukum market area as reference for "Ultra Modern" vicinity -->
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3941.546799854672!2d8.5115!3d7.7321!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x104e9e8e88e3e6c3%3A0x9a9a8a8a8a8a8a8a!2sModern%20Market%2C%20Makurdi!5e0!3m2!1sen!2sng!4v1630000000000!5m2!1sen!2sng"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <!-- Google reCAPTCHA v2 Script -->
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <partial name="_ValidationScriptsPartial" />
}

